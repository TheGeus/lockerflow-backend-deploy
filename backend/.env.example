DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gestionlocker?schema=public"
# DIRECT_URL se recomienda cuando DATABASE_URL usa pooler transaction mode
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gestionlocker?schema=public"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="8h"
PRISMA_DEPLOY_MODE="deploy"
PORT=3000
# Coma-separated list for browser clients. Example: https://lockerflow-admin.onrender.com,https://tu-dominio.com
CORS_ORIGIN="http://localhost:5173"
