generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeRole {
  EMPLOYEE
  ADMIN
}

enum IntegrationType {
  NONE
  MOCK
  API
  SENSOR
}

enum SizeCategory {
  S
  M
  L
}

enum CompartmentStatus {
  LIBRE
  RESERVADO
  OCUPADO
  BLOQUEADO
  AVERIADO
}

enum PackageStatus {
  PENDING_ASSIGNMENT
  ASSIGNED
  STORED
  OVERFLOW
  RETRIEVAL_IN_PROGRESS
  RETRIEVED
  CANCELLED
}

enum OverflowStatus {
  WAITING
  REASSIGNED
  REJECTED
  CANCELLED
}

enum PickupAttemptStatus {
  PENDING
  AUTHORIZED
  OPENED
  FAILED
  CONFIRMED
}

enum IncidentType {
  OPEN_FAILURE
  STATE_MISMATCH
  HARDWARE_ERROR
  MANUAL_OVERRIDE
  SECURITY_ALERT
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model Employee {
  id             BigInt          @id @default(autoincrement())
  username       String          @unique @db.VarChar(100)
  passwordHash   String          @map("password_hash")
  role           EmployeeRole    @default(EMPLOYEE)
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  packages       Package[]       @relation("PackageCreatedBy")
  pickupAttempts PickupAttempt[]
  auditEvents    AuditEvent[]

  @@map("employees")
}

model Person {
  id           BigInt    @id @default(autoincrement())
  externalQrId String    @unique @map("external_qr_id") @db.VarChar(150)
  documentId   String?   @map("document_id") @db.VarChar(100)
  fullName     String    @map("full_name") @db.VarChar(200)
  phone        String?   @db.VarChar(50)
  email        String?   @db.VarChar(200)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  packages     Package[]

  @@map("people")
}

model Locker {
  id              BigInt          @id @default(autoincrement())
  code            String          @unique @db.VarChar(50)
  name            String          @db.VarChar(150)
  location        String?         @db.VarChar(200)
  integrationType IntegrationType @default(MOCK) @map("integration_type")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  compartments    Compartment[]
  incidents       Incident[]

  @@map("lockers")
}

model Compartment {
  id                   BigInt            @id @default(autoincrement())
  lockerId             BigInt            @map("locker_id")
  slotNumber           Int               @map("slot_number")
  sizeCategory         SizeCategory      @map("size_category")
  status               CompartmentStatus @default(LIBRE)
  reservedForPackageId BigInt?           @unique @map("reserved_for_package_id")
  lastStatusChangeAt   DateTime          @default(now()) @map("last_status_change_at") @db.Timestamptz(6)
  locker               Locker            @relation(fields: [lockerId], references: [id])
  reservedForPackage   Package?          @relation("CompartmentReservedPackage", fields: [reservedForPackageId], references: [id])
  assignedPackages     Package[]         @relation("PackageAssignedCompartment")
  pickupAttempts       PickupAttempt[]
  incidents            Incident[]

  @@unique([lockerId, slotNumber])
  @@map("compartments")
}

model Package {
  id                    BigInt          @id @default(autoincrement())
  trackingNumber        String          @unique @map("tracking_number") @db.VarChar(120)
  personId              BigInt          @map("person_id")
  sizeCategory          SizeCategory    @map("size_category")
  weightGrams           Int?            @map("weight_grams")
  status                PackageStatus   @default(PENDING_ASSIGNMENT)
  assignedCompartmentId BigInt?         @map("assigned_compartment_id")
  overflowReason        String?         @map("overflow_reason") @db.VarChar(200)
  createdByEmployeeId   BigInt          @map("created_by_employee_id")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  person                Person          @relation(fields: [personId], references: [id])
  createdByEmployee     Employee        @relation("PackageCreatedBy", fields: [createdByEmployeeId], references: [id])
  assignedCompartment   Compartment?    @relation("PackageAssignedCompartment", fields: [assignedCompartmentId], references: [id])
  reservedCompartment   Compartment?    @relation("CompartmentReservedPackage")
  pickupCode            PickupCode?
  pickupAttempts        PickupAttempt[]
  overflowItem          OverflowItem?
  incidents             Incident[]

  @@map("packages")
}

model PickupCode {
  id           BigInt    @id @default(autoincrement())
  packageId    BigInt    @unique @map("package_id")
  code         String    @unique @db.VarChar(32)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  attemptCount Int       @default(0) @map("attempt_count")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  package      Package   @relation(fields: [packageId], references: [id])

  @@map("pickup_codes")
}

model PickupAttempt {
  id                    BigInt              @id @default(autoincrement())
  packageId             BigInt              @map("package_id")
  compartmentId         BigInt              @map("compartment_id")
  requestedByEmployeeId BigInt?             @map("requested_by_employee_id")
  providedCode          String              @map("provided_code") @db.VarChar(32)
  gatewayMode           IntegrationType     @map("gateway_mode")
  status                PickupAttemptStatus
  errorMessage          String?             @map("error_message")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  package               Package             @relation(fields: [packageId], references: [id])
  compartment           Compartment         @relation(fields: [compartmentId], references: [id])
  requestedByEmployee   Employee?           @relation(fields: [requestedByEmployeeId], references: [id])

  @@map("pickup_attempts")
}

model OverflowItem {
  id        BigInt         @id @default(autoincrement())
  packageId BigInt         @unique @map("package_id")
  reason    String         @db.VarChar(200)
  status    OverflowStatus @default(WAITING)
  notes     String?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  package   Package        @relation(fields: [packageId], references: [id])

  @@map("overflow_items")
}

model Incident {
  id            BigInt         @id @default(autoincrement())
  lockerId      BigInt?        @map("locker_id")
  compartmentId BigInt?        @map("compartment_id")
  packageId     BigInt?        @map("package_id")
  type          IncidentType
  status        IncidentStatus @default(OPEN)
  message       String
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt    DateTime?      @map("resolved_at") @db.Timestamptz(6)
  locker        Locker?        @relation(fields: [lockerId], references: [id])
  compartment   Compartment?   @relation(fields: [compartmentId], references: [id])
  package       Package?       @relation(fields: [packageId], references: [id])

  @@map("incidents")
}

model AuditEvent {
  id                    BigInt    @id @default(autoincrement())
  entityType            String    @map("entity_type") @db.VarChar(100)
  entityId              BigInt    @map("entity_id")
  eventType             String    @map("event_type") @db.VarChar(100)
  performedByEmployeeId BigInt?   @map("performed_by_employee_id")
  payloadJson           Json      @default("{}") @map("payload_json")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  performedByEmployee   Employee? @relation(fields: [performedByEmployeeId], references: [id])

  @@map("audit_events")
}
